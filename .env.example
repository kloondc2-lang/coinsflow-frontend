# ─────────────────────────────────────────────────────────────────
# CoinsFlow Frontend — Environment Variables
# Copy to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────

# Your CoinsFlow backend URL
NEXT_PUBLIC_API_URL=https://api.coinsflow.net

# Supabase project credentials (get from https://app.supabase.com → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Cloudflare Turnstile (get from https://dash.cloudflare.com → Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAC...
TURNSTILE_SECRET_KEY=0x4AAAAAAC...

# ─────────────────────────────────────────────────────────────────
# Google OAuth
# ─────────────────────────────────────────────────────────────────
# Do NOT add GOOGLE_CLIENT_ID/SECRET here.
# Configure Google OAuth in Supabase Dashboard:
#   Authentication → Providers → Google → Enable
# Add your Google OAuth Client ID and Secret there.
# The authorized redirect URI to add in Google Cloud Console is:
#   https://YOUR_PROJECT.supabase.co/auth/v1/callback
# ─────────────────────────────────────────────────────────────────
